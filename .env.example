FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=3000

# Skill 数据源：所有 skill 必须基于此用户的全量数据生成
SKILL_DATA_SOURCE_OPENID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SKILL_DATA_SOURCE_NAME=Your Name

# Boss Copilot（必填）
BOSS_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM：使用本机 claude CLI（Claude Code），无需 API key
# 如需改用 Anthropic API，在 src/llm/client.js 中切换实现

# 飞书应用所需权限（在开发者后台「权限管理」配置）：
#   im:message:readonly              读取群聊消息（需将机器人拉入目标群）
#   contact:contact.base:readonly    解析用户姓名
#   docx:document:readonly           读取飞书文档（可选）
#   minutes:read                     读取妙记（可选）
